# 이 파일은 .env.local의 템플릿입니다. 실제 값은 .env.local에 채우세요 (.env.local은 gitignore됨).

# ──────────────── Supabase ────────────────
# Public — 브라우저 노출 OK.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — RLS 우회. 절대 브라우저로 노출하지 말 것.
# Supabase 대시보드 > Project Settings > API > service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────── Replicate (생성형 이미지) ────────────────
# Server-only.
# https://replicate.com/account/api-tokens 에서 발급.
REPLICATE_API_TOKEN=
# Replicate webhook 설정 시 표시되는 시크릿 (whsec_ 접두 포함). Standard Webhooks(svix) 호환.
REPLICATE_WEBHOOK_SECRET=

# ──────────────── Quiver Arrow API (벡터화) ────────────────
# Server-only. POST https://api.quiver.ai/v1/svgs/vectorizations
QUIVERAI_API_KEY=
QUIVERAI_MODEL=arrow-1.1

# ──────────────── App ────────────────
# 로컬 개발: http://localhost:3000
# 단, Replicate webhook 콜백을 받으려면 외부에서 도달 가능한 URL이어야 함 (ngrok/cloudflared, 또는 Vercel 배포 URL).
NEXT_PUBLIC_APP_URL=http://localhost:3000
